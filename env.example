# Copy this file to .env (repo root, or public/.env for local dev) and fill
# in the values below. Never commit the real .env to version control.
#
# Section 1 is what a brand-new site needs. Section 2 is optional,
# feature-gated configuration.

# ============================================================
# 1. Required for any deployment
# ============================================================

# Database. After filling these in, run `php scripts/setup-database.php`
# to create/align the full schema (idempotent; see README.md).
DB_HOST=
DB_PORT=3306
DB_NAME=
DB_USER=
DB_PASS=
# Set to "true" only if your host requires a TLS connection to MySQL.
DB_SSL=

# Admin OAuth login — GitHub. Create an OAuth app at
# https://github.com/settings/developers with callback URL
# https://yourdomain.com/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Admin OAuth login — Google. Create OAuth credentials at
# https://console.cloud.google.com/apis/credentials with callback URL
# https://yourdomain.com/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Login — Microsoft (optional). Register an app at
# https://portal.azure.com (Microsoft Entra ID → App registrations,
# "Accounts in any organizational directory and personal Microsoft accounts")
# with redirect URI https://yourdomain.com/auth/microsoft/callback
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Login — Facebook (optional). Create an app at
# https://developers.facebook.com with Facebook Login and redirect URI
# https://yourdomain.com/auth/facebook/callback — the app must be in Live
# mode (with the email permission approved) for the public to sign in.
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# Comma-separated identities allowed to bootstrap an admin/owner identity on
# first OAuth login. At least one of these is required to ever reach /admin.
# GitHub uses usernames; Facebook uses the numeric app-scoped user id shown
# after first member login; the rest use email addresses. ADMIN_EMAILS
# enables the email magic-link admin login (requires SMTP_* below).
ADMIN_GITHUB_USERNAMES=
ADMIN_GOOGLE_EMAILS=
ADMIN_MICROSOFT_EMAILS=
ADMIN_FACEBOOK_IDS=
ADMIN_EMAILS=

# Used as a generic fallback site name (page titles, email subject lines,
# outbound HTTP User-Agent strings) wherever the admin Site Identity screen
# hasn't set one yet. Optional — defaults to "My Site".
APP_NAME=

# ============================================================
# 2. Optional, feature-gated configuration
# ============================================================

# Canonical public origin, e.g. https://yourdomain.com (no trailing slash).
# Used as a fallback for canonical URLs/feeds/OG tags when the admin Site
# Identity screen's "Canonical Public URL" field is unset, and as the
# HTTP-Referer sent to OpenRouter. If unset, falls back to the current
# request's Host header.
PUBLIC_SITE_URL=

# AES-256-GCM key (32 bytes, given as hex, base64, or a raw 32-byte string —
# generate with `openssl rand -hex 32`) used to encrypt AI vendor API keys.
# Required only if you configure any AI vendor profile under
# /admin/user-profiles.
AI_SETTINGS_ENCRYPTION_KEY=

# Sent to OpenRouter as X-OpenRouter-Title for API usage attribution. Purely
# cosmetic on OpenRouter's dashboard — unrelated to APP_NAME.
SITE_TITLE=

# Contact form: Google reCAPTCHA v3. Create a v3 property at
# https://www.google.com/recaptcha/admin for your domain.
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
RECAPTCHA_MIN_SCORE=0.5

# Contact form: outbound SMTP. Works with any standard SMTP provider (e.g.
# Gmail, AWS SES, Mailgun, Hostinger) — SMTP_USERNAME does not need to match
# SMTP_FROM_EMAIL (some providers issue opaque API-style usernames).
SMTP_HOST=
SMTP_PORT=587
SMTP_ENCRYPTION=starttls
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=
CONTACT_TO_EMAIL=

# Scheduled tasks: shared secret for the cron-protected endpoints
# (POST /api/cron/publish-posts and the feed-refresh cron route). Generate
# with `openssl rand -hex 32`. Only needed if you wire up scheduled
# publishing/feed-refresh (see .github/workflows/scheduled-tasks.yml).
CRON_SECRET=

# Platform publishing/social OAuth app credentials are not configured here.
# They are stored in the PHP site's own database under
# /admin/platform-connections so operators can manage them without env vars.
# This applies to WordPress.com, Blogger, LinkedIn, Facebook, and Instagram.
# Bluesky, Substack, and self-hosted WordPress likewise continue to be managed
# through the admin UI rather than env configuration.

# Legacy name for AI_SETTINGS_ENCRYPTION_KEY (Section 1). Still read as a
# fallback if AI_SETTINGS_ENCRYPTION_KEY is unset, for installs that set
# this before the rename. Do not set both to different values.
PLATFORM_AI_SETTINGS_ENCRYPTION_KEY=

# Platform sign-in OAuth values, kept separate from the admin OAuth in
# Section 1.
PLATFORM_GITHUB_ID=
PLATFORM_GITHUB_SECRET=
PLATFORM_GOOGLE_CLIENT_ID=
PLATFORM_GOOGLE_CLIENT_SECRET=

# Optional platform maintenance/API values.
PLATFORM_GH_TOKEN=
PLATFORM_PORT=
