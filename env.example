# .env.example - copy to public/.env for local use or create .env in
# Hostinger's public_html document root for production.
# Never commit .env to version control.

# Google reCAPTCHA v3
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
RECAPTCHA_MIN_SCORE=0.5

# Hostinger SMTP
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_ENCRYPTION=smtps
SMTP_USERNAME=contact@augmenthumankind.com
SMTP_PASSWORD=
SMTP_FROM_EMAIL=contact@augmenthumankind.com
SMTP_FROM_NAME="Augment Humankind"
CONTACT_TO_EMAIL=

# Current PHP target MySQL database - the only writable assimilation target.
DB_HOST=
DB_NAME=
DB_USER=
DB_PASS=

# Current PHP admin OAuth - GitHub
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Current PHP admin OAuth - Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Current PHP admin allowlists - comma-separated identities allowed to
# bootstrap an admin identity and owner user on first OAuth login.
ADMIN_GITHUB_USERNAMES=
ADMIN_GOOGLE_EMAILS=

# Platform source database - read/export only. Never point these at a database
# the migration tooling is allowed to mutate.
PLATFORM_DB_HOST=
PLATFORM_DB_PORT=3306
PLATFORM_DB_NAME=
PLATFORM_DB_USER=
PLATFORM_DB_PASS=
PLATFORM_DB_SSL=

# Platform-derived runtime configuration
PLATFORM_AUTH_SECRET=
PLATFORM_ALLOWED_ORIGINS=
PLATFORM_PUBLIC_SITE_URL=
PLATFORM_CRON_SECRET=
PLATFORM_AI_SETTINGS_ENCRYPTION_KEY=

# Platform sign-in OAuth values, kept separate from current PHP admin OAuth.
PLATFORM_GITHUB_ID=
PLATFORM_GITHUB_SECRET=
PLATFORM_GOOGLE_CLIENT_ID=
PLATFORM_GOOGLE_CLIENT_SECRET=

# Optional platform maintenance/API values
PLATFORM_GH_TOKEN=
PLATFORM_PORT=
