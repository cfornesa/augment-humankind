# .env.example — copy to public/.env for local use or create .env in
# Hostinger's public_html document root for production.
# Never commit .env to version control.
# See DECISIONS.md → Environment Variables Required for
# the full list of variables this project needs.

# Google reCAPTCHA v3
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
RECAPTCHA_MIN_SCORE=0.5

# Hostinger SMTP
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_ENCRYPTION=smtps
SMTP_USERNAME=contact@augmenthumankind.com
SMTP_PASSWORD=
SMTP_FROM_EMAIL=contact@augmenthumankind.com
SMTP_FROM_NAME="Augment Humankind"
CONTACT_TO_EMAIL=

# MySQL database (Portfolio + admin CMS) — point at the same MySQL instance
# used in production so dev and prod stay aligned.
DB_HOST=
DB_NAME=
DB_USER=
DB_PASS=

# Admin OAuth — GitHub
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Admin OAuth — Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Admin allowlists — comma-separated identities allowed to bootstrap an
# admin_identities row on first OAuth login.
ADMIN_GITHUB_USERNAMES=
ADMIN_GOOGLE_EMAILS=
